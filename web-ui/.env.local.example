NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_SECRET_KEY
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# Frontend SSE automatic resume policy
# Total number of resume requests after a disconnect. Set 0 to disable.
NEXT_PUBLIC_STREAM_RESUME_MAX_ATTEMPTS=3
# Delay before the second resume attempt.
NEXT_PUBLIC_STREAM_RESUME_BASE_DELAY_MS=1000
# Exponential backoff multiplier between resume attempts.
NEXT_PUBLIC_STREAM_RESUME_BACKOFF_MULTIPLIER=2
# Upper bound for the backoff delay.
NEXT_PUBLIC_STREAM_RESUME_MAX_DELAY_MS=5000
